#!/bin/bash
# Auto-bump minor version on every commit
# Updates all 4 version locations in the plugin project

MARKETPLACE="$(git rev-parse --show-toplevel)/.claude-plugin/marketplace.json"
SDD_SPEC="$(git rev-parse --show-toplevel)/plugins/sdd-spec/.claude-plugin/plugin.json"
SDD_ROI="$(git rev-parse --show-toplevel)/plugins/sdd-roi/.claude-plugin/plugin.json"

# Read current version from sdd-spec plugin.json
CURRENT=$(grep -oP '"version": "\K[0-9]+\.[0-9]+\.[0-9]+' "$SDD_SPEC" | head -1)

if [ -z "$CURRENT" ]; then
  echo "Warning: Could not read current version, skipping bump"
  exit 0
fi

# Parse and bump minor
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_MINOR=$((MINOR + 1))
NEW_VERSION="$MAJOR.$NEW_MINOR.$PATCH"

# Update plugin.json files — each reads its own current version
for FILE in "$SDD_SPEC" "$SDD_ROI"; do
  if [ -f "$FILE" ]; then
    FILE_VER=$(grep -oP '"version": "\K[0-9]+\.[0-9]+\.[0-9]+' "$FILE" | head -1)
    if [ -n "$FILE_VER" ]; then
      sed -i "s/\"version\": \"$FILE_VER\"/\"version\": \"$NEW_VERSION\"/" "$FILE"
      git add "$FILE"
    fi
  fi
done

# Update marketplace.json — context-aware per-plugin replacement via awk
# (avoids breakage when plugin versions have drifted out of sync)
if [ -f "$MARKETPLACE" ]; then
  awk -v ver="$NEW_VERSION" '
    /"name": "sdd-spec"/ { in_plugin=1 }
    /"name": "sdd-roi"/  { in_plugin=1 }
    in_plugin && /"version"/ {
      sub(/"version": "[^"]*"/, "\"version\": \"" ver "\"")
      in_plugin=0
    }
    { print }
  ' "$MARKETPLACE" > "$MARKETPLACE.tmp" && mv "$MARKETPLACE.tmp" "$MARKETPLACE"
  git add "$MARKETPLACE"
fi

echo "Version bumped: $CURRENT → $NEW_VERSION"

# Detect schema-related file changes
REPO_ROOT="$(git rev-parse --show-toplevel)"
MIGRATIONS_DIR="$REPO_ROOT/plugins/sdd-spec/skills/sdd-update/migrations"
MIGRATIONS_MD="$MIGRATIONS_DIR/migrations.md"
MIGRATION_FILE="$MIGRATIONS_DIR/v${NEW_VERSION}.md"

SCHEMA_CHANGED=$(git diff --cached --name-only | grep -E \
  "plugins/sdd-spec/skills/(spec-format|sdd-init)/SKILL\.md|plugins/sdd-spec/skills/doc/SKILL\.md")

# Update migrations.md index (add new version at top, DESC order)
if [ -f "$MIGRATIONS_MD" ]; then
  if [ -n "$SCHEMA_CHANGED" ]; then
    MIGRATION_ENTRY="| v${NEW_VERSION} | [v${NEW_VERSION}.md](v${NEW_VERSION}.md) |"
  else
    MIGRATION_ENTRY="| v${NEW_VERSION} | - |"
  fi
  awk -v entry="$MIGRATION_ENTRY" '
    /^\|---/ { print; print entry; next }
    { print }
  ' "$MIGRATIONS_MD" > "$MIGRATIONS_MD.tmp" && mv "$MIGRATIONS_MD.tmp" "$MIGRATIONS_MD"
  git add "$MIGRATIONS_MD"
fi

# Generate migration file if schema changed
if [ -n "$SCHEMA_CHANGED" ] && [ ! -f "$MIGRATION_FILE" ]; then
  echo "Schema changes detected, generating migration file v${NEW_VERSION}.md..."
  CHANGED_FILES=$(echo "$SCHEMA_CHANGED" | tr '\n' ', ' | sed 's/,$//')
  PROMPT="Generate a migration file for sdd-spec plugin version ${NEW_VERSION}. The following schema-related files changed: ${CHANGED_FILES}. Output only the migration file content in markdown. Start with '# v${NEW_VERSION} — <brief title>'. Then list the migration steps as bash commands or edit instructions for the user's .sdd/config.json. Focus only on changes the user needs to apply to their existing project data. If no user data migration is needed, output exactly: '# v${NEW_VERSION}\n\nAucune migration nécessaire.'"
  CONTENT=$(claude --print "$PROMPT" 2>/dev/null)
  if [ -n "$CONTENT" ]; then
    printf "%s\n" "$CONTENT" > "$MIGRATION_FILE"
    echo "Migration file generated: v${NEW_VERSION}.md"
  else
    printf "# v%s\n\nTODO: décrire les étapes de migration si nécessaire.\n" "$NEW_VERSION" > "$MIGRATION_FILE"
    echo "Migration file created (placeholder): v${NEW_VERSION}.md"
  fi
  git add "$MIGRATION_FILE"
  echo "⚠  Review the migration file and add steps if user data migration is needed."
fi
