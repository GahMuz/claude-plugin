#!/bin/bash
# Auto-bump minor version on every commit
# Updates all 4 version locations in the plugin project

MARKETPLACE="$(git rev-parse --show-toplevel)/.claude-plugin/marketplace.json"
SDD_SPEC="$(git rev-parse --show-toplevel)/plugins/sdd-spec/.claude-plugin/plugin.json"
SDD_ROI="$(git rev-parse --show-toplevel)/plugins/sdd-roi/.claude-plugin/plugin.json"

# Read current version from sdd-spec plugin.json
CURRENT=$(grep -oP '"version": "\K[0-9]+\.[0-9]+\.[0-9]+' "$SDD_SPEC" | head -1)

if [ -z "$CURRENT" ]; then
  echo "Warning: Could not read current version, skipping bump"
  exit 0
fi

# Parse and bump minor
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_MINOR=$((MINOR + 1))
NEW_VERSION="$MAJOR.$NEW_MINOR.$PATCH"

# Update plugin.json files — each reads its own current version
for FILE in "$SDD_SPEC" "$SDD_ROI"; do
  if [ -f "$FILE" ]; then
    FILE_VER=$(grep -oP '"version": "\K[0-9]+\.[0-9]+\.[0-9]+' "$FILE" | head -1)
    if [ -n "$FILE_VER" ]; then
      sed -i "s/\"version\": \"$FILE_VER\"/\"version\": \"$NEW_VERSION\"/" "$FILE"
      git add "$FILE"
    fi
  fi
done

# Update marketplace.json — context-aware per-plugin replacement via awk
# (avoids breakage when plugin versions have drifted out of sync)
if [ -f "$MARKETPLACE" ]; then
  awk -v ver="$NEW_VERSION" '
    /"name": "sdd-spec"/ { in_plugin=1 }
    /"name": "sdd-roi"/  { in_plugin=1 }
    in_plugin && /"version"/ {
      sub(/"version": "[^"]*"/, "\"version\": \"" ver "\"")
      in_plugin=0
    }
    { print }
  ' "$MARKETPLACE" > "$MARKETPLACE.tmp" && mv "$MARKETPLACE.tmp" "$MARKETPLACE"
  git add "$MARKETPLACE"
fi

echo "Version bumped: $CURRENT → $NEW_VERSION"

# Check if schema-related files changed and a migration file is needed
REPO_ROOT="$(git rev-parse --show-toplevel)"
MIGRATIONS_DIR="$REPO_ROOT/plugins/sdd-spec/skills/spec-migrate/migrations"
MIGRATION_FILE="$MIGRATIONS_DIR/v${NEW_VERSION}.md"

SCHEMA_CHANGED=$(git diff --cached --name-only | grep -E \
  "plugins/sdd-spec/skills/(spec-format|spec-init)/SKILL\.md|plugins/sdd-spec/skills/doc/SKILL\.md")

if [ -n "$SCHEMA_CHANGED" ] && [ ! -f "$MIGRATION_FILE" ]; then
  echo "Schema changes detected, generating migration file v${NEW_VERSION}.md..."

  DIFF=$(git diff --cached -- \
    "plugins/sdd-spec/skills/spec-format/SKILL.md" \
    "plugins/sdd-spec/skills/spec-init/SKILL.md" \
    "plugins/sdd-spec/skills/doc/SKILL.md")

  PROMPT="Tu es un expert du plugin sdd-spec (spec-driven development pour Claude Code).
Génère le contenu du fichier de migration v${NEW_VERSION}.md pour migrer les projets utilisateurs depuis la version précédente.

Règles :
- Décris uniquement les opérations sur les fichiers de données utilisateur (.sdd/, .specs/)
- Étapes en bash concrètes si nécessaire
- En français
- Format : '# v${NEW_VERSION} — <titre concis>' suivi de Steps numérotés
- Si aucune action utilisateur requise : écrire uniquement '# v${NEW_VERSION}\n\nAucune migration nécessaire.'

Diff des fichiers de schéma :
${DIFF}"

  claude --print "$PROMPT" > "$MIGRATION_FILE"
  git add "$MIGRATION_FILE"
  echo "Migration file generated and staged: v${NEW_VERSION}.md"
fi
