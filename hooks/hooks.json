{
  "description": "Spec-driven development workflow hooks — sync spec documents on user feedback",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/spec-sync-check.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
